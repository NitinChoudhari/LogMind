# Copy to .env and pick a provider.

# openai | ollama  -> drives BOTH the LLM and the embeddings
PROVIDER=openai

# --- OpenAI -----------------------------------------------------------------
OPENAI_API_KEY=sk-your-key
OPENAI_LLM=gpt-4o-mini
OPENAI_EMBED=text-embedding-3-small

# --- Ollama (fully local, runs on your RTX 4060) ----------------------------
# Pull models first:  ollama pull llama3.1:8b-instruct-q4_K_M  &&  ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM=llama3.1:8b-instruct-q4_K_M
OLLAMA_EMBED=nomic-embed-text

# Let the Researcher agent drive retrieval via the tool (best with capable models).
# Leave unset for deterministic retrieval + exact citations.
# AGENTIC_RETRIEVAL=1

# --- Reranking (cross-encoder stage after hybrid retrieval) -----------------
# flashrank (light, local, default) | crossencoder (pip install sentence-transformers) | none
RERANKER=flashrank
RERANK_TOP_N=5      # chunks kept after rerank
CANDIDATE_K=12      # pool size fed to the reranker
# RERANK_MODEL=ms-marco-MiniLM-L-12-v2
